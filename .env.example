# Copy to .env and adjust for your environment. Never commit the real .env file.

# Postgres (async driver -- postgresql+asyncpg://)
DATABASE_URL=postgresql+asyncpg://ic_platform:ic_platform@localhost:5432/ic_platform

# Redis (Celery broker + result backend + shared cache/rate-limit state)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-in-every-environment
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=14

ENVIRONMENT=local

# Report Language Adapter (M7) -- structured JSON only is ever sent, never
# raw documents/PII beyond what's already in the structured facts (ADR-012).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Live MahaRERA adapter. The session token is saved to this file by a human
# solving a CAPTCHA: run `python scripts/setup_maharera_session.py`. There is
# no automated way to obtain it. Lasts ~100 minutes; the live adapter reads
# the file fresh on every request, so re-running the script needs no restart.
# Leave the default if config/ lives at the project root (normal case).
MAHARERA_TOKEN_FILE_PATH=./config/maharera_token.json
